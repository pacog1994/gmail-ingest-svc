{
  "name": "gmail-ingest-svc",
  "version": "1.0.0",
  "description": "ingestion service to get emails from Gmail",
  "homepage": "https://github.com/pacog1994/gmail-ingest-svc#readme",
  "bugs": {
    "url": "https://github.com/pacog1994/gmail-ingest-svc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pacog1994/gmail-ingest-svc.git"
  },
  "license": "ISC",
  "author": "Paco Gallegos",
  "type": "commonjs",
  "main": "src/index.js",
  "scripts": {
    "build": "tsc",
    "start": "tsc && node dist/index.js",
    "callback-server": "node dist/callBackServer.js",
    "auth-url": "node dist/auth/gmailAuthUrl.js",
    "generate-auth-url-flow": "tsc && concurrently --names  \"callback-server, auth\" --prefix-colors \"blue, green\" -s first \"npm run callback-server\" \"npm run auth-url\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "googleapis": "^170.1.0",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.1.0",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3"
  }
}